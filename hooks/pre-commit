#!/bin/bash
# Pre-commit hook: code quality checks
# ALL checks MUST pass. Zero tolerance for failures.
set -e

echo "🔍 Running pre-commit checks..."

# 1. Format check
echo "  fmt..."
cargo fmt --all -- --check || { echo "❌ Run 'cargo fmt'"; exit 1; }

# 2. Clippy (zero warnings)
echo "  clippy..."
if ! cargo clippy --workspace -- -D warnings 2>&1 | tee /dev/stderr | tail -1 | grep -q "^$"; then
    # Proper check: run clippy and fail on non-zero exit
    :
fi
# Simpler: just run it and let set -e catch failure
cargo clippy --workspace -- -D warnings || { echo "❌ Clippy errors"; exit 1; }

# 3. File length: max 240 CODE lines (blank lines and comment-only lines do NOT count)
echo "  file length..."
MAX_CODE_LINES=240
VIOLATIONS=""
for f in $(find src tests -name '*.rs' 2>/dev/null); do
    CODE_LINES=$(sed 's/[[:space:]]*$//' "$f" | grep -v '^\s*$' | grep -v '^\s*//' | grep -v '^\s*\*' | grep -v '^\s*/\*' | grep -v '^\s*\*/' | wc -l | tr -d ' ')
    if [ "$CODE_LINES" -gt "$MAX_CODE_LINES" ]; then
        VIOLATIONS="$VIOLATIONS\n  $f: $CODE_LINES code lines (max $MAX_CODE_LINES)"
    fi
done
if [ -n "$VIOLATIONS" ]; then
    echo -e "❌ Files exceed $MAX_CODE_LINES code lines:$VIOLATIONS"
    exit 1
fi

# 4. ALL tests MUST pass. Zero failures allowed.
echo "  tests..."
TEST_OUTPUT=$(cargo test --workspace --no-fail-fast 2>&1)
TEST_EXIT=$?
if [ $TEST_EXIT -ne 0 ]; then
    echo "$TEST_OUTPUT" | grep -E "FAILED|^error|failures:" | head -20
    echo "❌ Tests failed (exit code $TEST_EXIT)"
    exit 1
fi
# Double-check: ensure at least one test actually ran
if ! echo "$TEST_OUTPUT" | grep -q "test result:"; then
    echo "❌ No test results found — tests did not run!"
    exit 1
fi
# Ensure zero failures in output
if echo "$TEST_OUTPUT" | grep -q "FAILED"; then
    echo "$TEST_OUTPUT" | grep "FAILED"
    echo "❌ Test failures detected"
    exit 1
fi
# Ensure zero ignored/skipped tests
if echo "$TEST_OUTPUT" | grep -qE '[1-9][0-9]* ignored'; then
    echo "$TEST_OUTPUT" | grep 'ignored'
    echo "❌ Tests were skipped/ignored — all tests must run"
    exit 1
fi

# 5. No hardcoded colors in view/widget code (only palette definitions allowed)
echo "  hardcoded colors..."
ALLOWED_FILES="src/app_palette.rs|src/app_palette_defaults.rs|src/app_palette_roles.rs|src/app_palette_roles2.rs|src/config_colors.rs|src/highlight.rs|src/highlight_cache.rs|src/views/editor/draw_style.rs"
COLOR_VIOLATIONS=""
for f in $(find src -name '*.rs' | grep -Ev "$ALLOWED_FILES"); do
    HITS=$(grep -n 'Color::Ansi\|Color::Rgb' "$f" | grep -v '^\s*//' | grep -v 'unwrap_or' || true)
    if [ -n "$HITS" ]; then
        COLOR_VIOLATIONS="$COLOR_VIOLATIONS\n  $f:\n$HITS"
    fi
done
if [ -n "$COLOR_VIOLATIONS" ]; then
    echo -e "❌ Hardcoded colors found (use palette instead):$COLOR_VIOLATIONS"
    exit 1
fi

echo "✅ All checks passed"
