#!/bin/bash
# Pre-commit hook: code quality checks
set -e

echo "🔍 Running pre-commit checks..."

# 1. Format check
echo "  fmt..."
cargo fmt --all -- --check || { echo "❌ Run 'cargo fmt'"; exit 1; }

# 2. Clippy (includes unwrap/expect deny)
echo "  clippy..."
cargo clippy --workspace -- -D warnings 2>&1 | grep -q "^error" && { echo "❌ Clippy errors"; exit 1; } || true

# 3. File length: max 240 CODE lines (blank lines and comment-only lines do NOT count)
echo "  file length..."
MAX_CODE_LINES=240
VIOLATIONS=""
for f in $(find src txv-core/src txv-render/src txv-widgets/src rusticle/src rusticle-tk/src -name '*.rs' 2>/dev/null); do
    # Count lines that are NOT: blank, // comments, //! doc comments, /* */ block comments, or * continuation
    CODE_LINES=$(sed 's/[[:space:]]*$//' "$f" | grep -v '^\s*$' | grep -v '^\s*//' | grep -v '^\s*\*' | grep -v '^\s*/\*' | grep -v '^\s*\*/' | wc -l | tr -d ' ')
    if [ "$CODE_LINES" -gt "$MAX_CODE_LINES" ]; then
        VIOLATIONS="$VIOLATIONS\n  $f: $CODE_LINES code lines (max $MAX_CODE_LINES)"
    fi
done
if [ -n "$VIOLATIONS" ]; then
    echo -e "❌ Files exceed $MAX_CODE_LINES code lines:$VIOLATIONS"
    exit 1
fi

# 4. Tests pass (--no-fail-fast ensures ALL binaries run; exit code catches compile errors too)
echo "  tests..."
TEST_OUTPUT=$(cargo test --workspace --no-fail-fast 2>&1)
TEST_EXIT=$?
if [ $TEST_EXIT -ne 0 ]; then
    echo "$TEST_OUTPUT" | grep -E "^error|FAILED" | head -10
    echo "❌ Tests failed (exit code $TEST_EXIT)"
    exit 1
fi

echo "✅ All checks passed"
